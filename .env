# Database
# ─────────
# LOCAL DEV (SQLite — no server needed):
DATABASE_URL=file:/home/z/my-project/db/custom.db

# PRODUCTION (PostgreSQL — cPanel, Supabase, Neon, Railway, etc.):
# 1. Change prisma/schema.prisma: provider = "postgresql"
# 2. Set this to your PostgreSQL connection string:
# DATABASE_URL=postgresql://user:password@localhost:5432/trail_gliders?schema=public
# DATABASE_URL=postgresql://user:password@db.example.com:5432/trail_gliders?schema=public
#
# cPanel: create a PostgreSQL database + user in cPanel → PostgreSQL Databases
# Supabase: create a project at https://supabase.com, copy the connection string
# Neon: create a project at https://neon.tech, copy the connection string

